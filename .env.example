# The private key of your Celo wallet (Must have some CELO for gas fees)
# DO NOT include the "0x" prefix, or do, ethers handles either, but keep it secure.
CELO_PRIVATE_KEY=your_private_key_here

# The contract address of AgentRegistry.sol after you deploy it to Celo
AGENT_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
